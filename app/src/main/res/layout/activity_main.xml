<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/canvas"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gold Clock"
            android:textColor="@color/ink"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="实时黄金价格与铃声预警"
            android:textColor="@color/muted"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="当前金价"
                android:textColor="@color/muted"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cnyPriceText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="--"
                android:textColor="@color/ink"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/usdPriceText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="--"
                android:textColor="@color/muted"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/rateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="--"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="等待刷新"
                    android:textColor="@color/muted"
                    android:textSize="13sp" />

                <ProgressBar
                    android:id="@+id/refreshProgress"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/lastUpdatedText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="最后更新：--"
                android:textColor="@color/muted"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/refreshButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="立即刷新"
                android:textColor="@color/ink" />

            <Switch
                android:id="@+id/monitorSwitch"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="14dp"
                android:text="后台监测"
                android:textColor="@color/ink"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="黄金期货日 K"
                    android:textColor="@color/ink"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/refreshChartButton"
                    android:layout_width="86dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="刷新"
                    android:textColor="@color/ink" />
            </LinearLayout>

            <com.example.goldclock.KLineChartView
                android:id="@+id/kLineChartView"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/chartStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="等待加载 K 线"
                android:textColor="@color/muted"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card_alt"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="添加预警"
                android:textColor="@color/ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/conditionSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:entries="@array/alert_conditions" />

            <EditText
                android:id="@+id/thresholdInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:hint="预警价格"
                android:inputType="numberDecimal"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted" />

            <Spinner
                android:id="@+id/unitSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:entries="@array/alert_units" />

            <Button
                android:id="@+id/addAlertButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_primary"
                android:text="添加"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/testAlertButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_button_secondary"
                android:text="测试闹钟提醒"
                android:textColor="@color/ink" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="预警列表"
            android:textColor="@color/ink"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/emptyAlertsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:text="还没有预警。添加一个价格阈值后，后台监测会在首次进入触发区间时响铃通知。"
            android:textColor="@color/muted"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/alertList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
